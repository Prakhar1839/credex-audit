# Copy this to .env.local and fill in your values.
# The app works WITHOUT any of these — it falls back to local storage, console email, and templated summaries.

# ── Anthropic API (for AI-generated audit summaries) ──────────────────────────
# Get your key at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ── Supabase (for persistent audit + lead storage) ────────────────────────────
# Create a free project at: https://supabase.com
# Run the SQL in supabase/schema.sql after creating the project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # optional but recommended for server-side writes

# ── Resend (for transactional email) ─────────────────────────────────────────
# Get your key at: https://resend.com
RESEND_API_KEY=

# ── App URL (for shareable links and OG tags) ─────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# On Vercel, this is set automatically via VERCEL_URL — no need to set manually.
